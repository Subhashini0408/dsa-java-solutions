/*
Problem: Best Time to Buy and Sell Stock

Approach:
Track the minimum stock price while traversing the array.
For every day, calculate the possible profit by subtracting
the minimum price from the current price.
Update the maximum profit whenever a larger profit is found.

Time Complexity: O(n)
Space Complexity: O(1)
*/
class Solution {
    public int maxProfit(int[] prices) {

          int minprice = prices[0];
          int maxprofit = 0;

          for(int i = 1 ; i < prices.length ; i++)
          {
            if(prices[i] < minprice)
            {
                minprice = prices[i];
            }
            else
            {
                int profit = prices[i] - minprice;
                maxprofit = Math.max(maxprofit , profit);
            }
          }

          return maxprofit;
    }
}
